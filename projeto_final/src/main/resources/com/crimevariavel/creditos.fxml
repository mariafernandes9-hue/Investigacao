<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.crimevariavel.controller.CreditosController" alignment="CENTER" spacing="0" styleClass="fundo-cortica" stylesheets="@estilo.css">

    <!-- Carimbo topo -->
    <Label text="— DOCUMENTO CLASSIFICADO —" style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: #5a4020; -fx-letter-spacing: 4px; -fx-padding: 18 0 4 0;"/>

    <!-- Título principal com carimbo CRIME VARIÁVEL -->
    <StackPane alignment="CENTER" style="-fx-padding: 0 0 6 0;">
        <Label text="CRIME VARIÁVEL"
               style="-fx-font-family: 'Courier New'; -fx-font-size: 52px; -fx-font-weight: bold;
                      -fx-text-fill: #8b0000;
                      -fx-effect: dropshadow(gaussian, rgba(139,0,0,0.35), 6, 0, 2, 2);"/>
        
        <!-- Carimbo diagonal ENCERRADO -->
        <Label text="ENCERRADO"
               style="-fx-font-family: 'Courier New'; -fx-font-size: 22px; -fx-font-weight: bold;
                      -fx-text-fill: rgba(0,100,0,0.55); -fx-border-color: rgba(0,100,0,0.55);
                      -fx-border-width: 3px; -fx-border-radius: 3px;
                      -fx-padding: 3 10; -fx-rotate: -18;
                      -fx-translate-x: 160; -fx-translate-y: -8;"/>
    </StackPane>

    <Label text="────────────────────────────────────────────────────────" style="-fx-text-fill: #8b6914; -fx-font-size: 11px;"/>

    <!-- Corpo: dois "documentos" lado a lado -->
    <HBox spacing="20" alignment="CENTER" style="-fx-padding: 18 0 0 0;">

        <!-- Ficha esquerda: agentes -->
        <VBox spacing="10" alignment="CENTER"
              style="-fx-background-color: #f0dfa8; -fx-background-radius: 2px;
                     -fx-border-color: #c8a96e; -fx-border-width: 1px; -fx-border-radius: 2px;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 8, 0, 3, 3);
                     -fx-padding: 22 28 22 28; -fx-min-width: 280;">

            <Label text="FICHA DE AGENTES"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;
                          -fx-font-weight: bold; -fx-text-fill: #5a0000; -fx-letter-spacing: 2px;"/>
            <Label text="────────────────────────"
                   style="-fx-text-fill: #8b6914; -fx-font-size: 10px;"/>

            <Label text="CASO: CRIME VARIÁVEL"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: #5a4020;"/>
            <Label text="STATUS: CONCLUÍDO  ✓"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: #006600; -fx-font-weight: bold;"/>

            <Label text="────────────────────────"
                   style="-fx-text-fill: #8b6914; -fx-font-size: 10px;"/>

            <Label text="AGENTE 001"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: #5a4020;"/>
            <Label text="ISABELLY OVANI"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 18px; -fx-font-weight: bold;
                          -fx-text-fill: #1a0a00;"/>

            <Label text="────────────────────────"
                   style="-fx-text-fill: #8b6914; -fx-font-size: 10px;"/>

            <Label text="AGENTE 002"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: #5a4020;"/>
            <Label text="MARIA CLARA"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 18px; -fx-font-weight: bold;
                          -fx-text-fill: #1a0a00;"/>

            <Label text="────────────────────────"
                   style="-fx-text-fill: #8b6914; -fx-font-size: 10px;"/>

            <!-- Mini carimbo APROVADO -->
            <Label text="✦  APROVADO  ✦"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-text-fill: #8b0000; -fx-border-color: #8b0000; -fx-border-width: 2px;
                          -fx-border-radius: 2px; -fx-padding: 4 12; -fx-rotate: -6;"/>
        </VBox>

        <!-- Ficha direita: ficha técnica -->
        <VBox spacing="8" alignment="TOP_LEFT"
              style="-fx-background-color: #f0dfa8; -fx-background-radius: 2px;
                     -fx-border-color: #c8a96e; -fx-border-width: 1px; -fx-border-radius: 2px;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 8, 0, 3, 3);
                     -fx-padding: 22 28 22 28; -fx-min-width: 280;">

            <Label text="FICHA TÉCNICA"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;
                          -fx-font-weight: bold; -fx-text-fill: #5a0000; -fx-letter-spacing: 2px;"/>
            <Label text="────────────────────────"
                   style="-fx-text-fill: #8b6914; -fx-font-size: 10px;"/>

            <Label text="DISCIPLINA:"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: #5a4020; -fx-font-weight: bold;"/>
            <Label text="Técnicas de Programação II"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-text-fill: #1a0a00;"/>

            <Label text="INSTITUIÇÃO:"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: #5a4020; -fx-font-weight: bold;"/>
            <Label text="Instituto Federal de"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-text-fill: #1a0a00;"/>
            <Label text="Mato Grosso do Sul"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-text-fill: #1a0a00;"/>

            <Label text="────────────────────────"
                   style="-fx-text-fill: #8b6914; -fx-font-size: 10px;"/>

            <Label text="TECNOLOGIAS:"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: #5a4020; -fx-font-weight: bold;"/>
            <Label text="► Java 17"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-text-fill: #2a1a05;"/>
            <Label text="► JavaFX 21  +  FXML"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-text-fill: #2a1a05;"/>
            <Label text="► PostgreSQL  +  JDBC"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-text-fill: #2a1a05;"/>
            <Label text="► Maven  +  SceneBuilder"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-text-fill: #2a1a05;"/>

            <Label text="────────────────────────"
                   style="-fx-text-fill: #8b6914; -fx-font-size: 10px;"/>

            <Label text="GERAÇÃO DE CASOS:"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: #5a4020; -fx-font-weight: bold;"/>
            <Label text="Procedural  |  3 dificuldades"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-text-fill: #2a1a05;"/>
            <Label text="Centenas de casos únicos"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-text-fill: #2a1a05;"/>
        </VBox>

    </HBox>

    <!-- Rodapé -->
    <Label text="────────────────────────────────────────────────────────"
           style="-fx-text-fill: #8b6914; -fx-font-size: 11px; -fx-padding: 16 0 8 0;"/>

    <Label text="CONFIDENCIAL  ·  USO RESTRITO  ·  IFMS / TLP 2"
           style="-fx-font-family: 'Courier New'; -fx-font-size: 10px;
                  -fx-text-fill: #5a4020; -fx-letter-spacing: 2px;"/>

    <Button text="◀  ARQUIVAR E VOLTAR" onAction="#voltarMenu"
            prefWidth="220" prefHeight="36" styleClass="botao-etiqueta"
            style="-fx-margin: 0; -fx-padding: 0 0 0 0;" />

</VBox>
