<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.crimevariavel.controller.InventarioController" spacing="15" prefWidth="580" prefHeight="500" styleClass="janela-modal" stylesheets="@estilo.css">

    <Label text="INVENTÁRIO DO AGENTE"
           style="-fx-font-family: 'Courier New'; -fx-font-size: 20px;
                  -fx-font-weight: bold; -fx-text-fill: #8b0000; -fx-padding: 15 0 0 15;"/>

    <Label fx:id="labelJogador"
           style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;
                  -fx-text-fill: #8b6914; -fx-padding: 0 0 0 15;"/>

    <Label text="──────────────────────────────────────────────────"
           style="-fx-text-fill: #8b6914; -fx-padding: 0 0 0 15;"/>

    <ScrollPane fitToWidth="true" prefHeight="350"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox fx:id="areaItens" spacing="10"
              style="-fx-padding: 10 15 10 15; -fx-background-color: transparent;"/>
    </ScrollPane>

    <Button text="FECHAR" onAction="#fechar"
            prefWidth="150" styleClass="botao-etiqueta"
            style="-fx-margin: 0 0 10 215;"/>

</VBox>

